        const ACTION_PIN = "2233"; // \uc0\u3619 \u3627 \u3633 \u3626 \u3626 \u3635 \u3627 \u3619 \u3633 \u3610 \u3649 \u3585 \u3657 \u3652 \u3586 /\u3621 \u3610 \
        // ==========================================\
\
        let state = \{\
            activeCategory: 'flatbed', // \uc0\u3627 \u3617 \u3623 \u3604 \u3627 \u3617 \u3641 \u3656 \u3607 \u3637 \u3656 \u3651 \u3594 \u3657 \u3591 \u3634 \u3609 \u3629 \u3618 \u3641 \u3656 : 'flatbed' \u3627 \u3619 \u3639 \u3629  'semidump'\
            activeTab: 'overview',\
            filterYear: null,\
            filterMonth: null,\
            filterPeriod: null,\
            expandedTree: \{ \
                'flatbed_y2569': true, 'flatbed_y2569m6': true,\
                'semidump_y2569': true, 'semidump_y2569m6': true \
            \},\
