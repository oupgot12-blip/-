\
        // --- \uc0\u3619 \u3632 \u3610 \u3610 \u3585 \u3619 \u3629 \u3591 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621  (Filter Data) ---\
        function getFiltered(dataArr) \{\
