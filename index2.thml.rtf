                \} else throw new Error("\uc0\u3588 \u3635 \u3609 \u3623 \u3603 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 ");\
            \} catch (e) \{\
                alert("\uc0\u3648 \u3585 \u3636 \u3604 \u3586 \u3657 \u3629 \u3612 \u3636 \u3604 \u3614 \u3621 \u3634 \u3604 : " + e.message);\
            \} finally \{\
                btn.innerHTML = '<i data-lucide="map-pin" class="w-3 h-3 mr-1"></i>\uc0\u3588 \u3635 \u3609 \u3623 \u3603 \u3629 \u3633 \u3605 \u3650 \u3609 \u3617 \u3633 \u3605 \u3636 ';\
                lucide.createIcons();\
            \}\
        \};\
\
        async function submitData(e) \{\
            e.preventDefault();\
            const btn = document.getElementById('btn-submit-form');\
            btn.disabled = true;\
            btn.innerText = '\uc0\u3585 \u3635 \u3621 \u3633 \u3591 \u3610 \u3633 \u3609 \u3607 \u3638 \u3585 ...';\
\
            let newData = \{ \
                id: state.editMode ? state.formData.id : Date.now(),\
                category: state.editMode ? (state.formData.category || state.activeCategory) : state.activeCategory \
            \};\
            const getVal = (id) => document.getElementById(id)?.value;\
\
            if (state.activeTab === 'trips' || state.activeTab === 'refuels') \{\
                newData.date = formatToThaiShort(getVal('f_date'));\
                newData.plate = getVal('f_plate');\
            \}\
\
            let actionType = '';\
            if (state.activeTab === 'trips') \{\
                actionType = state.editMode ? 'editTrip' : 'addTrip';\
                Object.assign(newData, \{\
                    origin: getVal('f_origin'), dest: getVal('f_dest'),\
                    dist: Number(getVal('f_dist')), fuelRate: Number(getVal('f_fuelRate')),\
                    currentFuelPrice: Number(getVal('f_currentFuelPrice')), fuelCost: Number(getVal('f_fuelCost')),\
                    driverFee: Number(getVal('f_driverFee')), revenue: Number(getVal('f_revenue'))\
                \});\
                newData.profit = newData.revenue - newData.fuelCost - newData.driverFee;\
                if(state.editMode) state.trips = state.trips.map(t => t.id === newData.id ? newData : t);\
                else state.trips.unshift(newData);\
            \} else if (state.activeTab === 'refuels') \{\
                actionType = state.editMode ? 'editRefuel' : 'addRefuel';\
                Object.assign(newData, \{ liters: Number(getVal('f_liters')), price: Number(getVal('f_price')) \});\
                newData.total = newData.liters * newData.price;\
                if(state.editMode) state.refuels = state.refuels.map(r => r.id === newData.id ? newData : r);\
                else state.refuels.unshift(newData);\
            \} else if (state.activeTab === 'vehicles') \{\
                actionType = state.editMode ? 'editVehicle' : 'addVehicle';\
                Object.assign(newData, \{ plate: getVal('f_plate'), driver: getVal('f_driver'), type: getVal('f_type') \});\
                if(state.editMode) state.vehicles = state.vehicles.map(v => v.id === newData.id ? newData : v);\
                else state.vehicles.unshift(newData);\
            \} else if (state.activeTab === 'jobs') \{\
                actionType = state.editMode ? 'editJob' : 'addJob';\
                Object.assign(newData, \{ \
                    origin: getVal('f_origin'), dest: getVal('f_dest'), \
                    dist: Number(getVal('f_dist')), revenue: Number(getVal('f_revenue')) \
                \});\
                if(state.editMode) state.jobs = state.jobs.map(j => j.id === newData.id ? newData : j);\
                else state.jobs.unshift(newData);\
            \}\
\
            if(GAS_WEB_APP_URL && !GAS_WEB_APP_URL.includes("\uc0\u3651 \u3626 \u3656 _URL")) \{\
                try \{\
                    // \uc0\u3651 \u3627 \u3657 \u3627 \u3609 \u3657 \u3634 \u3648 \u3623 \u3655 \u3610 \u3651 \u3594 \u3657 \u3591 \u3634 \u3609 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3651 \u3627 \u3617 \u3656 \u3607 \u3633 \u3609 \u3607 \u3637  \u3650 \u3604 \u3618 \u3652 \u3617 \u3656 \u3605 \u3657 \u3629 \u3591 \u3619 \u3629 \u3650 \u3627 \u3621 \u3604 \u3651 \u3627 \u3617 \u3656 \
                    fetch(GAS_WEB_APP_URL, \{\
                        method: 'POST',\
                        body: JSON.stringify(\{ action: actionType, data: newData \}),\
                        mode: 'no-cors'\
                    \});\
                \} catch(e) \{\}\
            \}\
\
            document.getElementById('main-modal').classList.add('hidden');\
            renderNav();\
            renderContent();\
            btn.disabled = false;\
        \}\
\
        window.deleteData = async (id, actionStr, sheetType) => \{\
            if (!confirm("\uc0\u3588 \u3640 \u3603 \u3605 \u3657 \u3629 \u3591 \u3585 \u3634 \u3619 \u3621 \u3610 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3649 \u3606 \u3623 \u3609 \u3637 \u3657 \u3651 \u3594 \u3656 \u3627 \u3619 \u3639 \u3629 \u3652 \u3617 \u3656 ?")) return;\
            \
            document.getElementById('loading-spinner').classList.remove('hidden');\
            try \{\
                await fetch(GAS_WEB_APP_URL, \{\
                    method: 'POST',\
                    mode: 'no-cors',\
                    headers: \{ 'Content-Type': 'application/json' \},\
                    body: JSON.stringify(\{ action: actionStr, id: id, sheetType: sheetType \})\
                \});\
                \
                if (actionStr.includes('Trip')) state.trips = state.trips.filter(i => i.id !== id);\
                else if (actionStr.includes('Refuel')) state.refuels = state.refuels.filter(i => i.id !== id);\
                else if (actionStr.includes('Vehicle')) state.vehicles = state.vehicles.filter(i => i.id !== id);\
                else if (actionStr.includes('Job')) state.jobs = state.jobs.filter(i => i.id !== id);\
\
                renderNav();\
                renderContent();\
                alert("\uc0\u3621 \u3610 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592 !");\
            \} catch (e) \{\
                console.error(e);\
                alert("\uc0\u3648 \u3585 \u3636 \u3604 \u3586 \u3657 \u3629 \u3612 \u3636 \u3604 \u3614 \u3621 \u3634 \u3604 \u3651 \u3609 \u3585 \u3634 \u3619 \u3621 \u3610 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 ");\
            \} finally \{\
                document.getElementById('loading-spinner').classList.add('hidden');\
            \}\
        \};\
\
        window.openMapModal = () => \{\
            const mapHtml = `\
                <!DOCTYPE html><html lang="th"><head><meta charset="utf-8">\
                <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />\
                <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"><\\/script>\
                <style>body, html, #map \{ height: 100%; margin: 0; padding: 0; font-family: sans-serif; \} .search-panel \{ position: absolute; top: 15px; left: 50%; transform: translateX(-50%); z-index: 1000; background: rgba(255, 255, 255, 0.95); padding: 15px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.15); width: 90%; max-width: 400px; display: flex; flex-direction: column; gap: 10px; \} input, button \{ padding: 8px 12px; border-radius: 8px; border: 1px solid #cbd5e1; outline:none; \} button \{ background: #2563eb; color: white; border: none; cursor: pointer; font-weight: bold; \} #status \{ font-size: 12px; text-align: center; \}</style>\
                </head><body>\
                <div class="search-panel"><label style="font-size:12px;font-weight:bold;color:#475569;">\uc0\u55357 \u56525  \u3605 \u3657 \u3609 \u3607 \u3634 \u3591 </label><input type="text" id="ori" placeholder="\u3648 \u3594 \u3656 \u3609  \u3626 \u3619 \u3632 \u3610 \u3640 \u3619 \u3637  \u3627 \u3619 \u3639 \u3629  13.7,100.5"><label style="font-size:12px;font-weight:bold;color:#475569;">\u55356 \u57263  \u3611 \u3621 \u3634 \u3618 \u3607 \u3634 \u3591 </label><input type="text" id="dest" placeholder="\u3648 \u3594 \u3656 \u3609  \u3619 \u3632 \u3618 \u3629 \u3591 "><button id="calcBtn">\u3588 \u3657 \u3609 \u3627 \u3634 \u3649 \u3621 \u3632 \u3588 \u3635 \u3609 \u3623 \u3603 \u3619 \u3632 \u3618 \u3632 \u3607 \u3634 \u3591 </button><div id="status"></div></div><div id="map"></div>\
                <script>\
                const map = L.map("map").setView([13.75, 100.5], 6);\
                L.tileLayer("https://\{s\}.tile.openstreetmap.org/\{z\}/\{x\}/\{y\}.png").addTo(map);\
                let routeLayer = null, markers = [];\
                async function geocode(q) \{\
                    const m = q.match(/([\\\\d\\\\.]+)\\\\s*,\\\\s*([\\\\d\\\\.]+)/);\
                    if (m) return \{ lat: parseFloat(m[1]), lon: parseFloat(m[2]) \};\
                    const r = await fetch("https://nominatim.openstreetmap.org/search?format=json&q=" + encodeURIComponent(q) + "&limit=1&countrycodes=th");\
                    const d = await r.json();\
                    if (d && d.length > 0) return d[0];\
                    throw new Error("\uc0\u3652 \u3617 \u3656 \u3614 \u3610 \u3626 \u3606 \u3634 \u3609 \u3607 \u3637 \u3656 ");\
                \}\
                document.getElementById("calcBtn").onclick = async function() \{\
                    const ori = document.getElementById("ori").value;\
                    const dest = document.getElementById("dest").value;\
                    const statusEl = document.getElementById("status");\
                    if(!ori || !dest) return statusEl.innerText = "\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3585 \u3619 \u3629 \u3585 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3651 \u3627 \u3657 \u3588 \u3619 \u3610 ", statusEl.style.color="red";\
                    statusEl.innerText = "\uc0\u3585 \u3635 \u3621 \u3633 \u3591 \u3588 \u3657 \u3609 \u3627 \u3634 ..."; statusEl.style.color="blue"; this.disabled = true;\
                    try \{\
                        const [o, d] = await Promise.all([geocode(ori), geocode(dest)]);\
                        if(markers.length) \{ markers.forEach(m=>map.removeLayer(m)); markers=[]; \}\
                        if(routeLayer) map.removeLayer(routeLayer);\
                        markers.push(L.marker([o.lat, o.lon]).addTo(map).bindPopup("\uc0\u3605 \u3657 \u3609 \u3607 \u3634 \u3591 ").openPopup());\
                        markers.push(L.marker([d.lat, d.lon]).addTo(map).bindPopup("\uc0\u3611 \u3621 \u3634 \u3618 \u3607 \u3634 \u3591 "));\
                        statusEl.innerText = "\uc0\u3585 \u3635 \u3621 \u3633 \u3591 \u3604 \u3638 \u3591 \u3648 \u3626 \u3657 \u3609 \u3607 \u3634 \u3591 ...";\
                        const res = await fetch("https://router.project-osrm.org/route/v1/driving/" + o.lon + "," + o.lat + ";" + d.lon + "," + d.lat + "?overview=full&geometries=geojson");\
                        const data = await res.json();\
                        if(data.code === "Ok") \{\
                            const dist = (data.routes[0].distance / 1000).toFixed(0);\
                            routeLayer = L.geoJSON(data.routes[0].geometry, \{style: \{color: "#3b82f6", weight: 5\}\}).addTo(map);\
                            map.fitBounds(routeLayer.getBounds(), \{padding:[50,50]\});\
                            statusEl.innerText = "\uc0\u3619 \u3632 \u3618 \u3632 \u3607 \u3634 \u3591 : " + dist + " \u3585 \u3617 . (\u3585 \u3635 \u3621 \u3633 \u3591 \u3626 \u3656 \u3591 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3585 \u3621 \u3633 \u3610 )";\
                            statusEl.style.color = "green";\
                            setTimeout(() => \{ window.parent.postMessage(\{ type: "MAP_SELECTED", dist: dist, origin: ori, dest: dest \}, "*"); \}, 1500);\
                        \} else throw new Error("\uc0\u3652 \u3617 \u3656 \u3614 \u3610 \u3648 \u3626 \u3657 \u3609 \u3607 \u3634 \u3591 ");\
                    \} catch(e) \{ statusEl.innerText = e.message; statusEl.style.color="red"; \}\
                    this.disabled = false;\
                \};\
                <\\/script></body></html>\
            `;\
            document.getElementById('map-iframe').srcdoc = mapHtml;\
            document.getElementById('map-modal').classList.remove('hidden');\
        \};\
\
        const closeMapModal = () => document.getElementById('map-modal').classList.add('hidden');\
        document.getElementById('btn-close-map').onclick = closeMapModal;\
        document.getElementById('btn-close-map-bottom').onclick = closeMapModal;\
\
        window.addEventListener('message', (event) => \{\
            if (event.data && event.data.type === 'MAP_SELECTED') \{\
                document.getElementById('f_dist').value = event.data.dist;\
                document.getElementById('f_origin').value = event.data.origin;\
                document.getElementById('f_dest').value = event.data.dest;\
                calcFuelCost();\
                closeMapModal();\
            \}\
        \});\
\
        async function initApp() \{\
            renderNav();\
            if(!GAS_WEB_APP_URL || GAS_WEB_APP_URL.includes("\uc0\u3651 \u3626 \u3656 _URL")) return;\
\
            try \{\
                document.getElementById('loading-spinner').classList.remove('hidden');\
                const res = await fetch(GAS_WEB_APP_URL);\
                const data = await res.json();\
                if(data.status === 'success') \{\
                    state.trips = data.trips || [];\
                    state.refuels = data.refuels || [];\
                    state.vehicles = data.vehicles || [];\
                    state.jobs = data.jobs || [];\
                    renderNav();\
                    renderContent();\
                \}\
            \} catch (e) \{ console.error("Load error", e); \}\
            finally \{\
                document.getElementById('loading-spinner').classList.add('hidden');\
            \}\
        \}\
\
        // \uc0\u3648 \u3619 \u3636 \u3656 \u3617 \u3605 \u3657 \u3609 \u3585 \u3634 \u3619 \u3607 \u3635 \u3591 \u3634 \u3609 : \u3649 \u3626 \u3604 \u3591 \u3627 \u3609 \u3657 \u3634  PIN Login \u3648 \u3611 \u3655 \u3609 \u3629 \u3633 \u3609 \u3604 \u3633 \u3610 \u3649 \u3619 \u3585 \
        document.addEventListener('DOMContentLoaded', () => \{\
            lucide.createIcons();\
            showPinModal('login');\
        \});\
    </script>\
</body>\
