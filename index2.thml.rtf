                    const order = parseInt(year) * 100 + parseInt(parts[1]) * 10 + (day <= 15 ? 1 : 2); \
\
                    if (!dataMap[key]) dataMap[key] = \{ name: key, \uc0\u3585 \u3635 \u3652 \u3619 : 0, \u3618 \u3629 \u3604 \u3619 \u3633 \u3610 : 0, \u3588 \u3656 \u3634 \u3609 \u3657 \u3635 \u3617 \u3633 \u3609 : 0, order \};\
