            const totalRefuelAmount = filteredRefuels.reduce((s, r) => s + Number(r.total || 0), 0);\
            const tripsCount = filteredTrips.length;\
\
            const dataMap = \{\};\
            filteredTrips.forEach(trip => \{\
                const formattedDate = formatDisplayDate(trip.date);\
                const parts = String(formattedDate).split('/');\
                if (parts.length === 3) \{\
                    const day = parseInt(parts[0], 10);\
                    const monthStr = monthNames[parseInt(parts[1], 10) - 1] || parts[1];\
                    const year = parts[2];\
                    const periodLabel = day <= 15 ? '\uc0\u3623 \u3633 \u3609 \u3607 \u3637 \u3656  1-15' : '\u3623 \u3633 \u3609 \u3607 \u3637 \u3656  16-\u3626 \u3636 \u3657 \u3609 \u3648 \u3604 \u3639 \u3629 \u3609 ';\
