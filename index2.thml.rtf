    <script>\
        // \uc0\u55357 \u56391 \u55357 \u56391 \u55357 \u56391  \u3609 \u3635  URL \u3586 \u3629 \u3591  Google Apps Script \u3617 \u3634 \u3651 \u3626 \u3656 \u3605 \u3619 \u3591 \u3609 \u3637 \u3657  \u55357 \u56391 \u55357 \u56391 \u55357 \u56391 \
        const GAS_WEB_APP_URL = "https://script.google.com/macros/s/AKfycbxRVpvho5238-scXeZAtdpES-21NvQdGTD_V4UzwZJtz2CnNJQEqSz21qnZiCjGNYlGFw/exec";\
