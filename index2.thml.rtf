\
        function renderNav() \{\
            const navMenu = document.getElementById('nav-menu');\
            let html = '';\
\
            categories.forEach(cat => \{\
                html += `<div class="mb-10">`;\
                html += `\
                    <h3 class="px-2 text-[17px] font-extrabold text-blue-900 mb-4 flex items-center">\
                        <div class="bg-blue-100 p-1.5 rounded-lg mr-2"><i data-lucide="$\{cat.icon\}" class="w-5 h-5 text-blue-600"></i></div>\
