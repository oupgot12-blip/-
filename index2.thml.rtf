                `;\
                \
                const isOv = state.activeCategory === cat.id && state.activeTab === 'overview';\
                html += `\
                    <button onclick="changeTab('$\{cat.id\}', 'overview')" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all mb-4 $\{isOv ? 'bg-blue-50 text-blue-700 font-bold shadow-sm' : 'text-slate-600 hover:bg-slate-100'\}">\
                        <i data-lucide="layout-dashboard" class="h-5 w-5"></i><span>\uc0\u3616 \u3634 \u3614 \u3619 \u3623 \u3617  (Dashboard)</span>\
                    </button>\
                `;\
\
                const treeYears = [\
                    \{ year: 2569, startMonth: 6, endMonth: 12 \},\
                    \{ year: 2570, startMonth: 1, endMonth: 12 \}\
