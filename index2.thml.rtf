                data: \{ labels: labels, datasets: [ \{ label: '\uc0\u3585 \u3635 \u3652 \u3619 ', data: profit, backgroundColor: '#10b981', borderRadius: 4 \}, \{ label: '\u3588 \u3656 \u3634 \u3609 \u3657 \u3635 \u3617 \u3633 \u3609 ', data: fuel, backgroundColor: '#f59e0b', borderRadius: 4 \} ] \},\
                options: \{ responsive: true, maintainAspectRatio: false, plugins: \{ legend: \{ position: 'top' \} \}, scales: \{ y: \{ beginAtZero: true \} \} \}\
