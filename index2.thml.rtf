                cancelBtn.classList.remove('hidden');\
            \}\
\
            overlay.classList.remove('hidden');\
            setTimeout(() => input.focus(), 100);\
        \};\
\
        window.handlePinInput = (val) => \{\
            const cleanVal = val.replace(/\\D/g, '');\
            const input = document.getElementById('pinInput');\
            input.value = cleanVal;\
\
            if (cleanVal.length === 4) \{\
                const type = document.getElementById('pinOverlay').dataset.pinType;\
                const expected = (type === 'login') ? LOGIN_PIN : ACTION_PIN;\
\
                setTimeout(() => \{\
                    if (cleanVal === expected) \{\
                        document.getElementById('pinOverlay').classList.add('hidden');\
                        if (type === 'login') \{\
                            initApp(); // \uc0\u3650 \u3627 \u3621 \u3604 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3588 \u3619 \u3633 \u3657 \u3591 \u3649 \u3619 \u3585 \u3627 \u3621 \u3633 \u3591 \u3648 \u3586 \u3657 \u3634 \u3626 \u3641 \u3656 \u3619 \u3632 \u3610 \u3610 \
                        \} else if (window.pendingActionFunc) \{\
                            window.pendingActionFunc();\
                            window.pendingActionFunc = null;\
                        \}\
                    \} else \{\
                        alert("\uc0\u3619 \u3627 \u3633 \u3626  PIN \u3652 \u3617 \u3656 \u3606 \u3641 \u3585 \u3605 \u3657 \u3629 \u3591 !");\
                        input.value = "";\
                        input.focus();\
                    \}\
                \}, 150);\
            \}\
