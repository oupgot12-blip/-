\
        const monthNames = ["\uc0\u3617 \u3585 \u3619 \u3634 \u3588 \u3617 ", "\u3585 \u3640 \u3617 \u3616 \u3634 \u3614 \u3633 \u3609 \u3608 \u3660 ", "\u3617 \u3637 \u3609 \u3634 \u3588 \u3617 ", "\u3648 \u3617 \u3625 \u3634 \u3618 \u3609 ", "\u3614 \u3620 \u3625 \u3616 \u3634 \u3588 \u3617 ", "\u3617 \u3636 \u3606 \u3640 \u3609 \u3634 \u3618 \u3609 ", "\u3585 \u3619 \u3585 \u3598 \u3634 \u3588 \u3617 ", "\u3626 \u3636 \u3591 \u3627 \u3634 \u3588 \u3617 ", "\u3585 \u3633 \u3609 \u3618 \u3634 \u3618 \u3609 ", "\u3605 \u3640 \u3621 \u3634 \u3588 \u3617 ", "\u3614 \u3620 \u3624 \u3592 \u3636 \u3585 \u3634 \u3618 \u3609 ", "\u3608 \u3633 \u3609 \u3623 \u3634 \u3588 \u3617 "];\
        const formatCurrency = (num) => new Intl.NumberFormat('th-TH', \{ style: 'currency', currency: 'THB', minimumFractionDigits: 0 \}).format(num || 0);\
        const formatNumber = (num) => new Intl.NumberFormat('th-TH', \{ minimumFractionDigits: 2, maximumFractionDigits: 2 \}).format(num || 0);\
        \
        const getToday = () => \{\
            const tzoffset = (new Date()).getTimezoneOffset() * 60000;\
            return (new Date(Date.now() - tzoffset)).toISOString().split('T')[0];\
        \};\
\
        const formatToThaiShort = (isoDate) => \{\
            if(!isoDate) return '';\
            const parts = isoDate.split('-');\
            if(parts.length !== 3) return isoDate;\
            let y = parseInt(parts[0], 10);\
            if (y < 2500) y += 543;\
            return parseInt(parts[2], 10) + '/' + parseInt(parts[1], 10) + '/' + y;\
        \};\
\
        const formatDisplayDate = (rawDate) => \{\
            if (!rawDate) return '-';\
            const strDate = String(rawDate);\
            if (strDate.includes('T')) \{\
                const d = new Date(strDate);\
                if (!isNaN(d.getTime())) \{\
                    let y = d.getFullYear();\
                    if (y >= 1900 && y < 2000) y = 2500 + (y % 100);\
                    else if (y >= 2000 && y < 2500) y += 543;\
                    return d.getDate() + '/' + (d.getMonth() + 1) + '/' + y;\
                \}\
            \}\
            return strDate;\
        \};\
\
        const reverseThaiToISO = (thaiDate) => \{\
            if(!thaiDate) return getToday();\
            const strDate = String(thaiDate);\
            if(strDate.includes('T')) \{\
                const d = new Date(strDate);\
                if(!isNaN(d.getTime())) \{\
                    let y = d.getFullYear();\
                    if (y >= 1900 && y < 2000) y = 2000 + (y % 100) - 43; \
                    else if (y > 2500) y -= 543;\
                    return y + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');\
                \}\
            \}\
            const parts = strDate.split('/');\
            if(parts.length !== 3) return getToday();\
            let y = parseInt(parts[2], 10);\
            if(y > 2500) y -= 543;\
            else if(y < 100) y = 2000 + y;\
            const m = parts[1].padStart(2, '0');\
            const d = parts[0].padStart(2, '0');\
            return y + '-' + m + '-' + d;\
        \};\
\
        // --- \uc0\u3619 \u3632 \u3610 \u3610 \u3588 \u3623 \u3634 \u3617 \u3611 \u3621 \u3629 \u3604 \u3616 \u3633 \u3618  PIN ---\
        window.pendingActionFunc = null;\
